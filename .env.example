N8N_VERSION=2.23.2
REDIS_VERSION=7.4.9-alpine
POSTGRES_VERSION=16-alpine

# Generate a stable key and keep it backed up. Changing it can break saved n8n credentials.
N8N_ENCRYPTION_KEY=replace-with-a-random-32-character-string

GENERIC_TIMEZONE=America/Chicago

REDIS_HOST=redis
REDIS_PORT=6379

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=n8n_local
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-a-strong-local-password
